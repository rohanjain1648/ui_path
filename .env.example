# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App
APP_ENV=development
SECRET_KEY=change_this_in_production_32chars

# Database (defaults to SQLite for local dev)
DATABASE_URL=sqlite:///./intelliflow_ap.db

# UiPath Orchestrator (for webhook callbacks)
UIPATH_ORCHESTRATOR_URL=https://cloud.uipath.com
UIPATH_TENANT=your_tenant
UIPATH_CLIENT_ID=your_client_id
UIPATH_CLIENT_SECRET=your_client_secret

# Approval thresholds (USD)
AUTO_APPROVE_THRESHOLD=500
MANAGER_APPROVAL_THRESHOLD=10000
CFO_APPROVAL_THRESHOLD=50000

# Matching tolerances
PO_MATCH_TOLERANCE_PERCENT=2.0
LINE_ITEM_TOLERANCE_PERCENT=5.0

# Notification (mock - replace with real SMTP in prod)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@yourcompany.com
SMTP_PASSWORD=your_app_password
