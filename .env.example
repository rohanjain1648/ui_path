# ─────────────────────────────────────────────────────────────────────────────
# IntelliFlow AP — Environment Configuration
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Groq API (FREE) ───────────────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq models (defaults shown — change only if you want to experiment)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_VISION=llama-3.2-90b-vision-preview

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change_this_in_production_use_32_random_chars

# Database — SQLite for local dev, Postgres for production
DATABASE_URL=sqlite:///./intelliflow_ap.db
# DATABASE_URL=postgresql://user:password@localhost:5432/intelliflow_ap

# ── UiPath Automation Cloud ───────────────────────────────────────────────────
# Step-by-step guide: see UIPATH_SETUP.md
#
# 1. Sign up at https://cloud.uipath.com (free 60-day enterprise trial)
# 2. Go to Admin > External Applications > Add Application
# 3. Choose "Confidential Application", grant scopes: OR.Tasks OR.Robots OR.Execution
# 4. Copy the Client ID and Client Secret below

UIPATH_ORCHESTRATOR_URL=https://cloud.uipath.com
UIPATH_ACCOUNT_NAME=your_org_name
UIPATH_TENANT_NAME=DefaultTenant
UIPATH_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
UIPATH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret — set any random string, paste the same in UiPath webhook config
UIPATH_WEBHOOK_SECRET=your_random_webhook_secret_here

# Release key for your BPMN process (found in Orchestrator > Processes)
UIPATH_PROCESS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Approval thresholds (USD) ─────────────────────────────────────────────────
AUTO_APPROVE_THRESHOLD=500
MANAGER_APPROVAL_THRESHOLD=10000
CFO_APPROVAL_THRESHOLD=50000

# ── Matching tolerances (%) ───────────────────────────────────────────────────
PO_MATCH_TOLERANCE_PERCENT=2.0
LINE_ITEM_TOLERANCE_PERCENT=5.0
